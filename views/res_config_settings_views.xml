<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_cb" model="ir.ui.view">
        <field name="name">res.config.settings.cb</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base_setup.action_general_configuration"/>
        <field name="arch" type="xml">
            <div id="integration_options" position="after">
                <h2>De Boekhalte CB</h2>
                <div class="row mt16 o_settings_container">
                    <div class="col-12 col-lg-6 o_setting_box">
                        <div class="o_setting_right_pane">
                            <label for="cb_config_id"/>
                            <div class="text-muted">
                                Selecteer de actieve CB-configuratie voor synchronisatie.
                            </div>
                            <div class="mt8">
                                <field name="cb_config_id"/>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </field>
    </record>
</odoo>
