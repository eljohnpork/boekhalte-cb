<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- CB Config Form View -->
    <record id="view_cb_config_form" model="ir.ui.view">
        <field name="name">cb.config.form</field>
        <field name="model">cb.config</field>
        <field name="arch" type="xml">
            <form string="De Boekhalte CB Configuratie">
                <header>
                    <button name="action_test_ftp_connection" string="Test FTP Verbinding"
                            type="object" class="btn-secondary"/>
                    <button name="action_run_full_sync" string="Volledige Sync Nu"
                            type="object" class="btn-primary"/>
                    <button name="action_run_stock_sync" string="Alleen Voorraad Sync"
                            type="object" class="btn-secondary"/>
                </header>
                <sheet>
                    <widget name="web_ribbon" title="Archief" bg_color="bg-danger"
                            attrs="{'invisible': [('active', '=', True)]}"/>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Naam configuratie"/>
                        </h1>
                    </div>

                    <group>
                        <group string="Status">
                            <field name="active"/>
                            <field name="last_catalog_sync"/>
                            <field name="last_stock_sync"/>
                            <field name="last_price_sync"/>
                        </group>
                        <group string="Laatste Sync Resultaten">
                            <field name="last_sync_created"/>
                            <field name="last_sync_updated"/>
                            <field name="last_sync_errors"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="FTP Instellingen" name="ftp">
                            <group>
                                <group string="Verbinding">
                                    <field name="ftp_host"/>
                                    <field name="ftp_port"/>
                                    <field name="ftp_user"/>
                                    <field name="ftp_password" password="True"/>
                                    <field name="ftp_use_tls"/>
                                </group>
                                <group string="Bestandspaden op FTP">
                                    <field name="ftp_catalog_path"/>
                                    <field name="ftp_stock_path"/>
                                    <field name="ftp_price_path"/>
                                </group>
                            </group>
                            <group string="Bestandsformaat">
                                <field name="file_format"/>
                                <field name="catalog_filename_pattern"/>
                                <field name="stock_filename_pattern"/>
                            </group>
                        </page>

                        <page string="Import Instellingen" name="import">
                            <group>
                                <group string="Producten">
                                    <field name="default_supplier_id"/>
                                    <field name="default_product_categ_id"/>
                                    <field name="create_missing_categories"/>
                                    <field name="update_existing_products"/>
                                    <field name="import_cover_images"/>
                                    <field name="archive_missing_products"/>
                                </group>
                                <group string="Voorraad">
                                    <field name="sync_stock"/>
                                    <field name="stock_location_id"/>
                                    <field name="leadtime_field"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- CB Config Tree View -->
    <record id="view_cb_config_tree" model="ir.ui.view">
        <field name="name">cb.config.tree</field>
        <field name="model">cb.config</field>
        <field name="arch" type="xml">
            <tree string="CB Configuraties">
                <field name="name"/>
                <field name="ftp_host"/>
                <field name="last_catalog_sync"/>
                <field name="last_stock_sync"/>
                <field name="last_sync_created"/>
                <field name="last_sync_updated"/>
                <field name="last_sync_errors"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <!-- Action -->
    <record id="action_cb_config" model="ir.actions.act_window">
        <field name="name">CB Configuratie</field>
        <field name="res_model">cb.config</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- NUR Codes view -->
    <record id="view_cb_nur_code_tree" model="ir.ui.view">
        <field name="name">cb.nur.code.tree</field>
        <field name="model">cb.nur.code</field>
        <field name="arch" type="xml">
            <tree string="NUR Codes" editable="bottom">
                <field name="code"/>
                <field name="name"/>
                <field name="product_categ_id"/>
            </tree>
        </field>
    </record>

    <record id="action_cb_nur_code" model="ir.actions.act_window">
        <field name="name">NUR Codes</field>
        <field name="res_model">cb.nur.code</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- Menu -->
    <menuitem id="menu_cb_root"
              name="De Boekhalte CB"
              sequence="90"
              web_icon="boekhalte_cb,static/description/icon.png"/>

    <menuitem id="menu_cb_sync"
              name="Synchronisatie"
              parent="menu_cb_root"
              sequence="10"/>

    <menuitem id="menu_cb_config"
              name="Configuratie"
              parent="menu_cb_sync"
              action="action_cb_config"
              sequence="10"/>

    <menuitem id="menu_cb_logs"
              name="Import Logs"
              parent="menu_cb_sync"
              action="action_cb_import_log"
              sequence="20"/>

    <menuitem id="menu_cb_nur"
              name="NUR Codes"
              parent="menu_cb_root"
              action="action_cb_nur_code"
              sequence="30"/>
</odoo>
